# Secrets — never commit. Commit .env.example with placeholders instead.
.env
.env.*
!.env.example
*.local
*.pem
*.key

# Per-repo Claude Code overrides.
.claude/*.local.md

# Dependencies
node_modules/
.pnpm-store/

# Build output — bundles are produced by tools/build.mjs, never committed.
dist/

# Untracked rescue inputs staged for later migration tasks (see the
# restructure plan); never commit this directory.
.rescue/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
