{
    "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
    "files": {
        "includes": [
            "tools/**",
            "packages/**",
            "template/**",
            "scripts/chomp/src/**",
            "!**/*.d.ts",
            "!**/*.json",
            "!**/dist",
            "!**/node_modules"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "suspicious": {
                "noExplicitAny": "error"
            },
            "style": {
                "noDefaultExport": "error",
                "useImportType": "error",
                "useConst": "error",
                "useTemplate": "error",
                "noNonNullAssertion": "warn",
                "useNamingConvention": "off"
            }
        }
    }
}
